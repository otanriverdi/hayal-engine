# ~/.gitignore file for C++ projects using CMake

# --- User Specific ---
# Ignore the build directory specified by the user
/build/

# --- Build Artifacts ---
# Compiled object files
*.o
*.obj
*.lo
*.la

# Precompiled header files
*.pch
*.gch

# Compiled static libraries
*.a
*.lib

# Compiled dynamic libraries / shared objects / executables
*.so
*.dylib
*.dll
*.exe
*.out
*.app

# Dependency files generated by compilers
*.d

# --- CMake Specific ---
# CMake cache and generated files (often inside build/, but good practice)
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
CTestTestfile.cmake
compile_commands.json

# Makefiles / Build System Files (usually in build/)
Makefile
*.make
*.ninja

.cache

# --- 
